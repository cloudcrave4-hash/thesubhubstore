# ============================================================================
# SECURITY NOTICE: This file is a TEMPLATE ONLY
# - NEVER commit .env with real secrets to Git
# - Add .env to .gitignore (already done)
# - In Netlify, add these to Site Settings → Environment
# ============================================================================

# [NETLIFY FUNCTION SECRETS]
# Required for Discord order alerts (optional but recommended)
# Get this from Discord Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# [ADMIN AUTHENTICATION]
# IMPORTANT:
# - Set this in Vercel or Netlify environment variables
# - It is injected into browser code at build time, so it is NOT truly secret on a public static site
# - Use a strong value anyway, and prefer real backend auth if you want true secrecy
ADMIN_PASSWORD=

# [VERCEL DEPLOY]
# Your live Vercel domain - used to prevent CSRF attacks
# Format: https://your-site.vercel.app
SITE_URL=https://thesubhubstore.vercel.app

# [SUPABASE SECRETS - Add to Netlify only, NOT in browser code]
# Service role key (KEEP SECRET) - only use in Netlify Functions
# Get from: Supabase Dashboard → Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=

# [PUBLIC VALUES - Safe to embed in browser code]
# Do not treat these as secrets. They can be injected at build time for cleaner config management.
PUBLIC_SUPABASE_URL=https://rfnfjuwuzihjxgamnyou.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_Y4aG9YCLOoX0mqtGL5yJfw_-fZolStZ
PUBLIC_STORE_EMAIL=theshubhub@gmail.com
PUBLIC_FORMSUBMIT_URL=https://formsubmit.co/theshubhub@gmail.com

# [OPTIONAL: Local development overrides]
# Use site-config.local.example.js to override browser values locally
# This allows testing with different configs without environment variables
